{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Bagel",
  "scopeName": "source.bagel",
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#declaration"
    },
    {
      "include": "#expression"
    }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.double-slash.bagel",
          "match": "//.*$"
        },
        {
          "name": "comment.block.bagel",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "declaration": {
      "patterns": [
        {
          "include": "#import-declaration"
        },
        {
          "include": "#const-declaration"
        },
        {
          "include": "#type-declaration"
        }
      ]
    },
    "const-declaration": {
      "name": "meta.declaration.bagel",
      "begin": "(?:\\b(export)\\s+)?\\b(const)\\b",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.export.bagel"
        },
        "2": {
          "name": "storage.type.bagel"
        }
      },
      "end": "(?=\\n|;)",
      "patterns": [
        {
          "include": "#type-annotation"
        },
        {
          "include": "#plain-identifier"
        },
        {
          "name": "keyword.operator.assignment.bagel",
          "match": "="
        },
        {
          "include": "#expression"
        }
      ]
    },
    "type-declaration": {
      "name": "meta.type.declaration.bagel",
      "begin": "(?:\\b(export)\\s+)?\\b(type)\\b",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.export.bagel"
        },
        "2": {
          "name": "storage.type.bagel"
        }
      },
      "end": "(?=\\n|;)",
      "patterns": [
        {
          "comment": "Type name identifier",
          "match": "(?<=type\\s)\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.type.bagel"
            }
          }
        },
        {
          "name": "keyword.operator.assignment.bagel",
          "match": "="
        },
        {
          "include": "#type-expression"
        }
      ]
    },
    "import-declaration": {
      "name": "meta.import.bagel",
      "begin": "\\b(from)\\b",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.import.bagel"
        }
      },
      "end": "(?=\\n|;)",
      "patterns": [
        {
          "include": "#string-literal"
        },
        {
          "name": "keyword.control.import.bagel",
          "match": "\\b(import)\\b"
        },
        {
          "name": "keyword.control.import.bagel",
          "match": "\\b(as)\\b"
        },
        {
          "name": "punctuation.definition.imports.begin.bagel",
          "match": "\\{"
        },
        {
          "name": "punctuation.definition.imports.end.bagel",
          "match": "\\}"
        },
        {
          "name": "punctuation.separator.comma.bagel",
          "match": ","
        },
        {
          "include": "#plain-identifier"
        }
      ]
    },
    "expression": {
      "patterns": [
        {
          "include": "#comment"
        },
        {
          "include": "#nil-literal"
        },
        {
          "include": "#boolean-literal"
        },
        {
          "include": "#number-literal"
        },
        {
          "include": "#string-literal"
        },
        {
          "include": "#array-literal"
        },
        {
          "include": "#object-literal"
        },
        {
          "include": "#if-else-expression"
        },
        {
          "include": "#function-expression"
        },
        {
          "include": "#invocation"
        },
        {
          "include": "#pipe-call-operator"
        },
        {
          "include": "#unary-operator"
        },
        {
          "include": "#markup-expression"
        },
        {
          "include": "#binary-operator"
        },
        {
          "include": "#js-keyword"
        },
        {
          "include": "#return-keyword"
        },
        {
          "include": "#plain-identifier"
        }
      ]
    },
    "js-keyword": {
      "name": "keyword.other.js.bagel",
      "match": "\\bjs\\b"
    },
    "return-keyword": {
      "name": "keyword.control.flow.bagel",
      "match": "\\breturn\\b"
    },
    "function-expression": {
      "patterns": [
        {
          "comment": "Arrow function with parenthesized parameters (possibly typed): (a: number, b) => ...",
          "name": "meta.function.arrow.bagel",
          "begin": "(\\()(?=[^)]*\\)\\s*(?::\\s*[a-zA-Z_(\\[{])?\\s*=>)",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.parameters.begin.bagel"
            }
          },
          "end": "(\\))\\s*(?:(:\\s*)([^=]*?)\\s*)?(=>)",
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.parameters.end.bagel"
            },
            "2": {
              "name": "punctuation.separator.type.bagel"
            },
            "3": {
              "patterns": [
                {
                  "include": "#type-expression"
                }
              ]
            },
            "4": {
              "name": "storage.type.function.arrow.bagel"
            }
          },
          "patterns": [
            {
              "include": "#function-parameter"
            },
            {
              "name": "punctuation.separator.comma.bagel",
              "match": ","
            }
          ]
        },
        {
          "comment": "Arrow function with single unparenthesized parameter: x => ...",
          "name": "meta.function.arrow.bagel",
          "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(=>)",
          "captures": {
            "1": {
              "name": "variable.parameter.bagel"
            },
            "2": {
              "name": "storage.type.function.arrow.bagel"
            }
          }
        }
      ]
    },
    "function-parameter": {
      "patterns": [
        {
          "comment": "Typed parameter: name: Type",
          "begin": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(:)",
          "beginCaptures": {
            "1": {
              "name": "variable.parameter.bagel"
            },
            "2": {
              "name": "punctuation.separator.type.bagel"
            }
          },
          "end": "(?=[,)=])",
          "patterns": [
            {
              "include": "#type-expression"
            }
          ]
        },
        {
          "comment": "Untyped parameter: name",
          "name": "variable.parameter.bagel",
          "match": "[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "if-else-expression": {
      "patterns": [
        {
          "name": "meta.if-else.bagel",
          "begin": "\\b(if)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.conditional.bagel"
            }
          },
          "end": "(?<=\\})",
          "patterns": [
            {
              "name": "keyword.control.conditional.bagel",
              "match": "\\b(else)\\b"
            },
            {
              "include": "#expression"
            }
          ]
        }
      ]
    },
    "invocation": {
      "patterns": [
        {
          "comment": "Method call: .name(",
          "name": "meta.function-call.bagel",
          "begin": "(\\.)([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
          "beginCaptures": {
            "1": {
              "name": "punctuation.accessor.bagel"
            },
            "2": {
              "name": "entity.name.function.bagel"
            },
            "3": {
              "name": "punctuation.definition.arguments.begin.bagel"
            }
          },
          "end": "(\\))",
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.arguments.end.bagel"
            }
          },
          "patterns": [
            {
              "include": "#expression"
            },
            {
              "name": "punctuation.separator.comma.bagel",
              "match": ","
            }
          ]
        },
        {
          "comment": "Free function call: name(",
          "name": "meta.function-call.bagel",
          "begin": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
          "beginCaptures": {
            "1": {
              "name": "entity.name.function.bagel"
            },
            "2": {
              "name": "punctuation.definition.arguments.begin.bagel"
            }
          },
          "end": "(\\))",
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.arguments.end.bagel"
            }
          },
          "patterns": [
            {
              "include": "#expression"
            },
            {
              "name": "punctuation.separator.comma.bagel",
              "match": ","
            }
          ]
        }
      ]
    },
    "nil-literal": {
      "name": "constant.language.nil.bagel",
      "match": "\\bnil\\b"
    },
    "boolean-literal": {
      "name": "constant.language.boolean.bagel",
      "match": "\\b(true|false)\\b"
    },
    "number-literal": {
      "name": "constant.numeric.bagel",
      "match": "\\b[0-9]+(?:\\.[0-9]+)?\\b"
    },
    "string-literal": {
      "name": "string.quoted.single.bagel",
      "begin": "'",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.bagel"
        }
      },
      "end": "'|$",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.bagel"
        }
      },
      "patterns": [
        {
          "name": "constant.character.escape.bagel",
          "match": "\\\\."
        }
      ]
    },
    "array-literal": {
      "name": "meta.array.literal.bagel",
      "begin": "\\[",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.array.begin.bagel"
        }
      },
      "end": "\\]",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.array.end.bagel"
        }
      },
      "patterns": [
        {
          "include": "#expression"
        },
        {
          "name": "punctuation.separator.comma.bagel",
          "match": ","
        }
      ]
    },
    "object-literal": {
      "name": "meta.object.literal.bagel",
      "begin": "\\{",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.object.begin.bagel"
        }
      },
      "end": "\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.object.end.bagel"
        }
      },
      "patterns": [
        {
          "include": "#const-declaration"
        },
        {
          "name": "meta.object.member.bagel",
          "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(:)",
          "captures": {
            "1": {
              "name": "variable.object.property.bagel"
            },
            "2": {
              "name": "punctuation.separator.key-value.bagel"
            }
          }
        },
        {
          "include": "#expression"
        },
        {
          "name": "punctuation.separator.comma.bagel",
          "match": ","
        }
      ]
    },
    "pipe-call-operator": {
      "comment": "UFCS pipe call: subject..function(args)",
      "name": "meta.pipe-call.bagel",
      "begin": "(\\.\\.)([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
      "beginCaptures": {
        "1": {
          "name": "keyword.operator.pipe.bagel"
        },
        "2": {
          "name": "entity.name.function.bagel"
        },
        "3": {
          "name": "punctuation.definition.arguments.begin.bagel"
        }
      },
      "end": "(\\))",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.arguments.end.bagel"
        }
      },
      "patterns": [
        {
          "include": "#expression"
        },
        {
          "name": "punctuation.separator.comma.bagel",
          "match": ","
        }
      ]
    },
    "unary-operator": {
      "name": "keyword.operator.logical.bagel",
      "match": "!"
    },
    "binary-operator": {
      "patterns": [
        {
          "name": "keyword.operator.nullish.bagel",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.logical.bagel",
          "match": "\\|\\||&&"
        },
        {
          "name": "keyword.operator.comparison.bagel",
          "match": "==|!=|<=|>=|<(?![a-zA-Z_/])|>"
        },
        {
          "name": "keyword.operator.arithmetic.bagel",
          "match": "[+\\-*/]"
        }
      ]
    },
    "markup-expression": {
      "patterns": [
        {
          "comment": "Self-closing markup tag: <tag attr='val' />",
          "name": "meta.tag.bagel",
          "begin": "(<)([a-zA-Z_][a-zA-Z0-9_]*)(?=[^>]*/>)",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.tag.begin.bagel"
            },
            "2": {
              "name": "entity.name.tag.bagel"
            }
          },
          "end": "(/>)",
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.tag.end.bagel"
            }
          },
          "patterns": [
            {
              "include": "#markup-attribute"
            }
          ]
        },
        {
          "comment": "Markup element with content: <tag>...</tag>",
          "name": "meta.tag.block.bagel",
          "begin": "(<)([a-zA-Z_][a-zA-Z0-9_]*)",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.tag.begin.bagel"
            },
            "2": {
              "name": "entity.name.tag.bagel"
            }
          },
          "end": "(</)([a-zA-Z_][a-zA-Z0-9_]*)(>)",
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.tag.begin.bagel"
            },
            "2": {
              "name": "entity.name.tag.bagel"
            },
            "3": {
              "name": "punctuation.definition.tag.end.bagel"
            }
          },
          "patterns": [
            {
              "include": "#markup-attribute"
            },
            {
              "comment": "Closing angle bracket of opening tag",
              "name": "punctuation.definition.tag.end.bagel",
              "match": ">"
            },
            {
              "include": "#markup-content"
            }
          ]
        }
      ]
    },
    "markup-content": {
      "patterns": [
        {
          "include": "#markup-expression"
        },
        {
          "comment": "Markup interpolation: {expression}",
          "name": "meta.embedded.expression.bagel",
          "begin": "(\\{)",
          "beginCaptures": {
            "1": {
              "name": "punctuation.section.embedded.begin.bagel"
            }
          },
          "end": "(\\})",
          "endCaptures": {
            "1": {
              "name": "punctuation.section.embedded.end.bagel"
            }
          },
          "patterns": [
            {
              "include": "#expression"
            }
          ]
        }
      ]
    },
    "markup-attribute": {
      "patterns": [
        {
          "comment": "Attribute with string value: name='value'",
          "begin": "([a-zA-Z_][a-zA-Z0-9_]*)(=)(')",
          "beginCaptures": {
            "1": {
              "name": "entity.other.attribute-name.bagel"
            },
            "2": {
              "name": "punctuation.separator.key-value.bagel"
            },
            "3": {
              "name": "punctuation.definition.string.begin.bagel"
            }
          },
          "end": "(')",
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.string.end.bagel"
            }
          },
          "contentName": "string.quoted.single.bagel"
        },
        {
          "comment": "Attribute with expression value: name={expr}",
          "begin": "([a-zA-Z_][a-zA-Z0-9_]*)(=)(\\{)",
          "beginCaptures": {
            "1": {
              "name": "entity.other.attribute-name.bagel"
            },
            "2": {
              "name": "punctuation.separator.key-value.bagel"
            },
            "3": {
              "name": "punctuation.section.embedded.begin.bagel"
            }
          },
          "end": "(\\})",
          "endCaptures": {
            "1": {
              "name": "punctuation.section.embedded.end.bagel"
            }
          },
          "patterns": [
            {
              "include": "#expression"
            }
          ]
        },
        {
          "comment": "Bare attribute: name",
          "name": "entity.other.attribute-name.bagel",
          "match": "[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "plain-identifier": {
      "name": "variable.other.bagel",
      "match": "\\b(?!true\\b|false\\b|nil\\b|const\\b|export\\b|from\\b|import\\b|as\\b|if\\b|else\\b|typeof\\b|type\\b|js\\b|return\\b)[a-zA-Z_][a-zA-Z0-9_]*\\b"
    },
    "type-annotation": {
      "name": "meta.type.annotation.bagel",
      "begin": ":",
      "beginCaptures": {
        "0": {
          "name": "punctuation.separator.type.bagel"
        }
      },
      "end": "(?==(?!>))",
      "patterns": [
        {
          "include": "#type-expression"
        }
      ]
    },
    "type-expression": {
      "patterns": [
        {
          "include": "#typeof-type-expression"
        },
        {
          "include": "#function-type-expression"
        },
        {
          "include": "#primitive-type"
        },
        {
          "include": "#range-type-expression"
        },
        {
          "include": "#object-type-expression"
        },
        {
          "include": "#parenthesized-type-expression"
        },
        {
          "comment": "Array type suffix []",
          "name": "punctuation.definition.typeparameters.bagel",
          "match": "\\[\\]"
        },
        {
          "comment": "Tuple type [T, U]",
          "begin": "\\[",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.typeparameters.begin.bagel"
            }
          },
          "end": "\\]",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.typeparameters.end.bagel"
            }
          },
          "patterns": [
            {
              "include": "#type-expression"
            },
            {
              "name": "punctuation.separator.comma.bagel",
              "match": ","
            }
          ]
        },
        {
          "comment": "Union type separator",
          "name": "keyword.operator.type.union.bagel",
          "match": "\\|"
        },
        {
          "comment": "Nillable type suffix",
          "name": "keyword.operator.type.nillable.bagel",
          "match": "\\?"
        },
        {
          "comment": "Named type reference",
          "name": "entity.name.type.bagel",
          "match": "\\b(?!unknown\\b|nil\\b|boolean\\b|number\\b|string\\b|typeof\\b)[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "primitive-type": {
      "name": "support.type.primitive.bagel",
      "match": "\\b(unknown|nil|boolean|number|string)\\b"
    },
    "range-type-expression": {
      "comment": "Range type: 0..10, ..5, 1..",
      "name": "meta.type.range.bagel",
      "match": "(-?[0-9]+)?(\\.\\.)(-?[0-9]+)?",
      "captures": {
        "1": {
          "name": "constant.numeric.bagel"
        },
        "2": {
          "name": "keyword.operator.range.bagel"
        },
        "3": {
          "name": "constant.numeric.bagel"
        }
      }
    },
    "object-type-expression": {
      "comment": "Object type: {name: string, age: number}",
      "name": "meta.type.object.bagel",
      "begin": "\\{",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.object.begin.bagel"
        }
      },
      "end": "\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.object.end.bagel"
        }
      },
      "patterns": [
        {
          "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(:)",
          "captures": {
            "1": {
              "name": "variable.object.property.bagel"
            },
            "2": {
              "name": "punctuation.separator.key-value.bagel"
            }
          }
        },
        {
          "include": "#type-expression"
        },
        {
          "name": "punctuation.separator.comma.bagel",
          "match": ","
        }
      ]
    },
    "function-type-expression": {
      "comment": "Function type: (a: number, b: string) => boolean",
      "name": "meta.type.function.bagel",
      "begin": "(\\()(?=[^)]*\\)\\s*=>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.parameters.begin.bagel"
        }
      },
      "end": "(\\))\\s*(=>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.parameters.end.bagel"
        },
        "2": {
          "name": "storage.type.function.arrow.bagel"
        }
      },
      "patterns": [
        {
          "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(:)",
          "captures": {
            "1": {
              "name": "variable.parameter.bagel"
            },
            "2": {
              "name": "punctuation.separator.type.bagel"
            }
          }
        },
        {
          "include": "#type-expression"
        },
        {
          "name": "punctuation.separator.comma.bagel",
          "match": ","
        }
      ]
    },
    "parenthesized-type-expression": {
      "comment": "Parenthesized type: (number | string)",
      "begin": "\\(",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.type.begin.bagel"
        }
      },
      "end": "\\)",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.type.end.bagel"
        }
      },
      "patterns": [
        {
          "include": "#type-expression"
        }
      ]
    },
    "typeof-type-expression": {
      "comment": "typeof keyword in type position: typeof <expression>",
      "begin": "\\b(typeof)\\b",
      "beginCaptures": {
        "1": {
          "name": "keyword.operator.expression.typeof.bagel"
        }
      },
      "end": "(?=[,)\\]=|}])",
      "patterns": [
        {
          "include": "#expression"
        }
      ]
    }
  }
}
