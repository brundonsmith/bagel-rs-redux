---
source: tests/types.rs
expression: "test_infer(common :: samples :: MARKUP)"
---
const a = <br />
const b = <h1>hello</h1>
const c = <div count={1 + 2}>stuff</div>
const d = <h1 prop='foo'><span>stuff</span> other</h1>
const e = <div>{name}</div>
const f = <input disabled />
const g = <p></p>
---
'foo' -> 'foo'
1 -> 1
1 + 2 -> 3
2 -> 2
<br /> -> { attributes: {  }, children: [], tag: 'br' }
<div count={1 + 2}>stuff</div> -> { attributes: { count: 3 }, children: ['stuff'], tag: 'div' }
<div>{name}</div> -> { attributes: {  }, children: [unknown], tag: 'div' }
<h1 prop='foo'><span>stuff</span> other</h1> -> { attributes: { prop: 'foo' }, children: [{ attributes: {  }, children: ['stuff'], tag: 'span' }, ' other'], tag: 'h1' }
<h1>hello</h1> -> { attributes: {  }, children: ['hello'], tag: 'h1' }
<input disabled /> -> { attributes: { disabled: true }, children: [], tag: 'input' }
<p></p> -> { attributes: {  }, children: [], tag: 'p' }
<span>stuff</span> -> { attributes: {  }, children: ['stuff'], tag: 'span' }
name -> unknown
